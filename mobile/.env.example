# Copy this to .env and fill in your values

# Your deployed Render backend URL (or LAN IP for local dev: http://192.168.x.x:8000)
EXPO_PUBLIC_API_URL=https://your-render-app.onrender.com

# Firebase (same project as the web app)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Google OAuth Client ID (Web client ID from Firebase console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# PayPal client ID (same as web)
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# eSewa merchant ID
EXPO_PUBLIC_ESEWA_MERCHANT_ID=EPAYTEST

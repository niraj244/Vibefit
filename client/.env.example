# Backend API URL — use http://localhost:8000 for local dev
# Use your Render/Railway URL for production, e.g. https://yourapp.onrender.com
VITE_API_URL=http://localhost:8000

# Firebase config (from Firebase Console > Project Settings > Your apps)
VITE_FIREBASE_APP_API_KEY=your_firebase_api_key
VITE_FIREBASE_APP_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_APP_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_APP_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_APP_ID=your_app_id

# PayPal Client ID (PUBLIC key only — from developer.paypal.com)
VITE_APP_PAYPAL_CLIENT_ID=your_paypal_client_id

PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>

# Gmail credentials (use App Password from Google Account > Security > 2-Step > App Passwords)
EMAIL=yourname@gmail.com
EMAIL_PASS=your_google_app_password

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JSON_WEB_TOKEN_SECRET_KEY=your_long_random_secret_here
SECRET_KEY_ACCESS_TOKEN=your_long_random_access_token_secret_here
SECRET_KEY_REFRESH_TOKEN=your_long_random_refresh_token_secret_here

# Cloudinary (from cloudinary.com dashboard)
cloudinary_Config_Cloud_Name=your_cloud_name
cloudinary_Config_api_key=your_api_key
cloudinary_Config_api_secret=your_api_secret

# PayPal (from developer.paypal.com)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID_TEST=your_paypal_sandbox_client_id
PAYPAL_SECRET_TEST=your_paypal_sandbox_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# For live payments (replace sandbox values above with these when going live)
PAYPAL_CLIENT_ID_LIVE=your_paypal_live_client_id
PAYPAL_SECRET_LIVE=your_paypal_live_secret

# eSewa (from esewa.com.np merchant portal)
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_ENVIRONMENT=test

# CORS: Comma-separated list of allowed frontend domains
# Example: https://yourstore.vercel.app,https://youradmin.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Pathao Nepal Courier API (get from Pathao developer portal)
PATHAO_TRACKING_URL=https://pathao.com/np/parcel/
PATHAO_BASE_URL=
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_GRANT_TYPE=password
# Add the exact tracking/status endpoint from Pathao Nepal developer docs
PATHAO_TRACKING_ENDPOINT=
